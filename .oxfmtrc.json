{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 120,
  "jsxSingleQuote": true,
  "sortImports": {
    "newlinesBetween": false,
    "groups": [
      "type-import",
      ["value-builtin", "value-external"],
      "type-internal",
      "value-internal",
      ["type-parent", "type-sibling", "type-index"],
      ["value-parent", "value-sibling", "value-index"],
      "unknown"
    ]
  },
  "sortTailwindcss": {
    "stylesheet": "client/src/index.css",
    "functions": ["cn", "cva"]
  },
  "sortPackageJson": true,
  "ignorePatterns": ["node_modules/", "client/dist/", "client/src/routeTree.gen.ts", "drizzle/"]
}
